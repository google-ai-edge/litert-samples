<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="end"
    android:paddingHorizontal="16dp"
    android:paddingVertical="4dp">

    <!-- Image thumbnail (if present) -->
    <ImageView
        android:id="@+id/ivUserImage"
        android:layout_width="180dp"
        android:layout_height="140dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_image_rounded"
        android:clipToOutline="true"
        android:visibility="gone"
        android:layout_marginBottom="6dp"
        android:contentDescription="User attached image"
        tools:visibility="visible" />

    <!-- Message bubble -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bubble_user"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:orientation="vertical"
        android:maxWidth="300dp">

        <TextView
            android:id="@+id/tvUserMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.3"
            tools:text="Describe this image in detail." />

        <TextView
            android:id="@+id/tvUserTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp"
            android:layout_marginTop="4dp"
            android:layout_gravity="end"
            tools:text="12:34 PM" />
    </LinearLayout>
</LinearLayout>
