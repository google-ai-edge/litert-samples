<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.FastVLM" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorPrimaryDark">@color/accent_primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_accent</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/accent_secondary</item>
        <item name="colorOnSecondary">@color/text_primary</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/background_primary</item>
        <item name="colorSurface">@color/background_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/background_card</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/background_primary</item>
        <item name="android:navigationBarColor">@color/background_primary</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>

        <!-- Window background -->
        <item name="android:windowBackground">@color/background_primary</item>
    </style>
</resources>