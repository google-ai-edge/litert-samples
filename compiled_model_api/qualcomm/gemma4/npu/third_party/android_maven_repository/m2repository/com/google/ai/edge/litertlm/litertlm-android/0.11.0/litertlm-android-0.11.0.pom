  <modelVersion>4.0.0</modelVersion>
  <groupId>com.google.ai.edge.litertlm</groupId>
  <artifactId>litertlm-android</artifactId>
  <version>0.11.0</version>
  <packaging>aar</packaging>
  
<name>LiteRT-LM Android API</name>
<description>Kotlin API to efficiently run language models on Android via LiteRT-LM.</description>
<url>https://github.com/google-ai-edge/LiteRT-LM</url>
<inceptionYear>2025</inceptionYear>

